rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user has a specific role (or fallback email list)
    function hasRole(role) {
      return request.auth != null && (
        // Admin email checks
        (role == 'Admin' && (
          request.auth.token.email == 'board@summithoa.com' ||
          request.auth.token.email == 'cdulinpa@gmail.com' ||
          request.auth.token.email == 'mchang@hoa-admin.com'
        )) ||
        // Board Member email checks
        (role == 'Board Member' && (
          request.auth.token.email == 'sjenkins@hoa.community' ||
          request.auth.token.email == 'mvance@hoa.community' ||
          request.auth.token.email == 'wvu_vip@yahoo.com'
        )) ||
        // Standard database lookup
        (exists(/databases/$(database)/documents/residents/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/residents/$(request.auth.uid)).data.role == role)
      );
    }

    // Helper to check if user is admin
    function isAdmin() {
      return hasRole('Admin');
    }

    // Residents Directory rules
    match /residents/{residentId} {
      // Anyone can read resident details (needed for portal directory view)
      allow read: if true;
      
      // Allow creation of a new resident document if they are authenticated
      allow create: if request.auth != null;
      
      // Allow users to update their own profiles, or Admins to update any profile
      allow update: if request.auth != null && (
        request.auth.uid == residentId || 
        isAdmin()
      );
      
      // Only Admins can delete profiles
      allow delete: if isAdmin();
    }

    // Support Tickets rules
    match /tickets/{ticketId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null && (
        (exists(/databases/$(database)/documents/residents/$(request.auth.uid)) && 
         resource.data.author == get(/databases/$(database)/documents/residents/$(request.auth.uid)).data.name) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Clubhouse Bookings rules
    match /bookings/{bookingId} {
      allow read, create: if request.auth != null;
      allow delete: if request.auth != null && (
        (exists(/databases/$(database)/documents/residents/$(request.auth.uid)) && 
         resource.data.residentName == get(/databases/$(database)/documents/residents/$(request.auth.uid)).data.name) || 
        isAdmin()
      );
    }

    // Announcements rules
    match /announcements/{announcementId} {
      // Anyone can view announcements
      allow read: if true;
      
      // Admins and Board Members can write announcements
      allow write: if hasRole('Admin') || hasRole('Board Member');
    }

    // ARC Requests rules
    match /arcRequests/{requestId} {
      allow read, create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Logs rules
    match /deliveryLogs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Contractors rules
    match /contractors/{contractorId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/residents/$(request.auth.uid)) && 
         resource.data.recommendedBy == get(/databases/$(database)/documents/residents/$(request.auth.uid)).data.name)
      );
    }

    // Mail queue rules (used by EmailJS or Extensions)
    match /mail/{mailId} {
      allow read, write: if request.auth != null;
    }
  }
}
